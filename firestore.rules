rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // CUSTOMERS COLLECTION
    // - Create: any authenticated user (registration flow)
    // - Read: only the document owner
    // - Update: only the document owner
    // - Delete: NOBODY (data retention policy)
    // ============================================================
    match /customers/{uid} {
      // Read own profile, ou admin lendo qualquer perfil (para aprovar cadastros)
      allow get: if request.auth != null
                 && (request.auth.uid == uid
                     || request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com']);

      // List: bloqueado. Lookup de login agora usa coleção login_index (sem dados sensíveis).
      allow list: if false;

      // Create own profile during registration
      // Validates: document ID must match auth UID, email must match auth email,
      // required fields must be present, no admin self-escalation
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.keys().hasAll(['email', 'tipo', 'codigoCliente', 'createdAt'])
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      // Update: o proprio cliente, ou admin aprovando/rejeitando cadastro
      allow update: if request.auth != null
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data)
                    && (
                      request.auth.uid == uid
                      || request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com']
                    );

      // Delete: explicitly denied
      allow delete: if false;
    }

    // ============================================================
    // LOGIN_INDEX COLLECTION
    // Mapa público codigoCliente/telefone -> { email, uid } para login lookup.
    // Não contém dados sensíveis (apenas email, que o cliente já usa para Firebase Auth).
    // Substitui o antigo `customers.list`, que vazava docs inteiros.
    // ============================================================
    match /login_index/{id} {
      allow get: if true;
      allow list: if false;

      // Criar: apenas o próprio dono pode indexar, e apenas se a chave ainda nao existe
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['email', 'uid', 'updatedAt']);

      // Update: apenas quem já é dono da chave
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['email', 'uid', 'updatedAt']);

      allow delete: if false;
    }

    // ============================================================
    // ORDERS COLLECTION
    // - Create: authenticated user, customerId must match UID
    // - Read (get): only the order owner
    // - List: authenticated users (frontend filters by customerId)
    // - Update/Delete: NOBODY (orders are immutable)
    // ============================================================
    match /orders/{orderId} {
      // Read individual order: only the owner
      allow get: if request.auth != null
                 && resource.data.customerId == request.auth.uid;

      // List orders: only own orders, max 50 per query
      allow list: if request.auth != null
                  && resource.data.customerId == request.auth.uid;

      // Create order: customerId must match auth UID, validar shape + limites
      allow create: if request.auth != null
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.keys().hasAll(['customerId', 'items', 'createdAt'])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 200
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      // Orders are immutable once created
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================
    // LEADS COLLECTION (guest checkout capture)
    // - Create: qualquer visitante (sem auth) com payload validado
    // - Read/List: apenas admin
    // - Update/Delete: ninguem
    // ============================================================
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['sessionId', 'items', 'createdAt'])
                    && request.resource.data.sessionId is string
                    && request.resource.data.sessionId.size() >= 8
                    && request.resource.data.sessionId.size() <= 128
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 100
                    && !('customerId' in request.resource.data)
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      allow get, list: if request.auth != null
                       && request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com'];

      allow update, delete: if false;
    }

    // ============================================================
    // PRODUCTS COLLECTION
    // - Read: public (catalog is visible to everyone)
    // - Write: only admins
    // ============================================================
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com'];
    }

    // ============================================================
    // CONFIG COLLECTION (catalog metadata)
    // - Read: public
    // - Write: only admins
    // ============================================================
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com'];
    }

    // ============================================================
    // ADMIN COLLECTION (future use)
    // Only accessible by users with admin custom claim
    // ============================================================
    match /admin/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.admin == true;
    }

    // ============================================================
    // COUNTERS COLLECTION (contador sequencial de codigos de cliente)
    // - Read: qualquer autenticado
    // - Create: inicializa com next=1 apenas
    // - Update: apenas incremento +1 (impede reset malicioso/manipulacao)
    // - Delete: ninguem
    // ============================================================
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['next'])
                    && request.resource.data.next is int
                    && request.resource.data.next >= 1
                    && request.resource.data.next <= 10;
      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly(['next'])
                    && request.resource.data.next is int
                    && request.resource.data.next == resource.data.next + 1;
      allow delete: if false;
    }

    // ============================================================
    // DEFAULT: Deny all unmatched paths
    // This is Firestore's default, but being explicit is safer.
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
