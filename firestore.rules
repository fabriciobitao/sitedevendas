rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // CUSTOMERS COLLECTION
    // - Create: any authenticated user (registration flow)
    // - Read: only the document owner
    // - Update: only the document owner
    // - Delete: NOBODY (data retention policy)
    // ============================================================
    match /customers/{uid} {
      // Read own profile only
      allow get: if request.auth != null && request.auth.uid == uid;

      // List: allow phone lookup for login (limit 1 only, safe because sensitive fields are encrypted)
      allow list: if request.query.limit <= 1;

      // Create own profile during registration
      // Validates: document ID must match auth UID, email must match auth email,
      // required fields must be present, no admin self-escalation
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.keys().hasAll(['email', 'tipo', 'nomeResponsavel', 'cpf', 'createdAt'])
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      // Update own profile only — cannot change email, createdAt, or escalate to admin
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      // Delete: explicitly denied
      allow delete: if false;
    }

    // ============================================================
    // ORDERS COLLECTION
    // - Create: authenticated user, customerId must match UID
    // - Read (get): only the order owner
    // - List: authenticated users (frontend filters by customerId)
    // - Update/Delete: NOBODY (orders are immutable)
    // ============================================================
    match /orders/{orderId} {
      // Read individual order: only the owner
      allow get: if request.auth != null
                 && resource.data.customerId == request.auth.uid;

      // List orders: only own orders, max 50 per query
      allow list: if request.auth != null
                  && resource.data.customerId == request.auth.uid;

      // Create order: customerId must match auth UID, must have required fields
      allow create: if request.auth != null
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.keys().hasAll(['customerId', 'items', 'createdAt']);

      // Orders are immutable once created
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================
    // LEADS COLLECTION (guest checkout capture)
    // - Create: qualquer visitante (sem auth) com payload validado
    // - Read/List: apenas admin
    // - Update/Delete: ninguem
    // ============================================================
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['sessionId', 'items', 'createdAt'])
                    && request.resource.data.sessionId is string
                    && request.resource.data.sessionId.size() >= 8
                    && request.resource.data.sessionId.size() <= 128
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 100
                    && !('customerId' in request.resource.data)
                    && !('role' in request.resource.data)
                    && !('isAdmin' in request.resource.data);

      allow get, list: if request.auth != null
                       && request.auth.token.email == 'fabricio.fazer@gmail.com';

      allow update, delete: if false;
    }

    // ============================================================
    // PRODUCTS COLLECTION
    // - Read: public (catalog is visible to everyone)
    // - Write: only admin (fabricio.fazer@gmail.com)
    // ============================================================
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'fabricio.fazer@gmail.com';
    }

    // ============================================================
    // CONFIG COLLECTION (catalog metadata)
    // - Read: public
    // - Write: only admin
    // ============================================================
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'fabricio.fazer@gmail.com';
    }

    // ============================================================
    // ADMIN COLLECTION (future use)
    // Only accessible by users with admin custom claim
    // ============================================================
    match /admin/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.admin == true;
    }

    // ============================================================
    // DEFAULT: Deny all unmatched paths
    // This is Firestore's default, but being explicit is safer.
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
