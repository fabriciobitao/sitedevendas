rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fichas cadastrais: fluxo atual gera PDF no client e envia via Web Share/WhatsApp.
    // Nenhum upload/leitura pelo Storage. Bloco removido — cai no default deny abaixo.
    // Se reativar upload no futuro, restringir read ao dono ou admin.

    // Product images - public read, admin-only write
    match /products/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in ['fabricio.fazer@gmail.com', 'fabiomenezes@gmail.com']
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Bloquear tudo o mais
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
